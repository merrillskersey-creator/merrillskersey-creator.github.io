<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Travel AI | Merrill Kersey</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --forest: #1e4d2b;
      --forest-light: #2d6b3f;
      --sky: #e8f4fd;
      --sand: #f5ede0;
      --accent: #e07b39;
      --white: #ffffff;
      --gray: #f0f0ec;
      --text: #1a1a1a;
      --muted: #6b7280;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: var(--gray); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; }

    nav { background: var(--forest); padding: 0.9rem 2rem; display: flex; justify-content: space-between; align-items: center; }
    nav .brand { font-family: 'Playfair Display', serif; color: #d4e8c2; font-size: 1.25rem; text-decoration: none; }
    nav .nav-links a { color: rgba(255,255,255,0.8); text-decoration: none; margin-left: 1.5rem; font-size: 0.88rem; font-weight: 500; transition: color 0.2s; }
    nav .nav-links a:hover { color: #fff; }

    .app-hero { background: linear-gradient(135deg, var(--forest) 0%, #3a7a4a 100%); color: white; padding: 3rem 2rem 2rem; text-align: center; }
    .app-hero .badge { background: rgba(255,255,255,0.15); color: #d4e8c2; padding: 0.3rem 0.9rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1rem; display: inline-block; }
    .app-hero h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 0.75rem; }
    .app-hero p { color: rgba(255,255,255,0.8); font-size: 1rem; max-width: 550px; margin: 0 auto; }

    .app-layout { display: grid; grid-template-columns: 300px 1fr; gap: 1.5rem; max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; flex: 1; }
    @media (max-width: 768px) { .app-layout { grid-template-columns: 1fr; } nav .nav-links { display: none; } }

    .sidebar { display: flex; flex-direction: column; gap: 1rem; }
    .card { background: var(--white); border-radius: 14px; padding: 1.25rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .card h3 { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 0.85rem; }

    .prompt-btn { width: 100%; text-align: left; background: var(--sand); border: none; border-radius: 8px; padding: 0.65rem 0.85rem; font-family: 'Inter', sans-serif; font-size: 0.85rem; color: var(--forest); font-weight: 500; cursor: pointer; transition: background 0.2s, transform 0.1s; display: block; margin-bottom: 0.5rem; }
    .prompt-btn:hover { background: #ead8c0; transform: translateX(2px); }
    .prompt-btn .emoji { margin-right: 0.5rem; }

    .mode-btn { width: 100%; padding: 0.6rem; border: 2px solid #e5e7eb; background: none; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: all 0.2s; margin-bottom: 0.4rem; color: var(--muted); }
    .mode-btn.active { border-color: var(--forest); background: #edf7ee; color: var(--forest); font-weight: 600; }

    .chat-area { display: flex; flex-direction: column; gap: 1rem; }
    .messages { background: var(--white); border-radius: 14px; padding: 1.5rem; min-height: 420px; max-height: 520px; overflow-y: auto; box-shadow: 0 2px 12px rgba(0,0,0,0.06); display: flex; flex-direction: column; gap: 1rem; }

    .message { display: flex; gap: 0.85rem; animation: slideIn 0.3s ease; }
    .message.user { flex-direction: row-reverse; }
    @keyframes slideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    .avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
    .avatar.ai { background: var(--forest); }
    .avatar.user { background: var(--accent); }

    .bubble { max-width: 80%; padding: 0.9rem 1.1rem; border-radius: 16px; font-size: 0.92rem; line-height: 1.65; }
    .message.ai .bubble { background: var(--sky); color: var(--text); border-bottom-left-radius: 4px; }
    .message.user .bubble { background: var(--forest); color: #fff; border-bottom-right-radius: 4px; }
    .bubble .ai-label { font-weight: 700; display: block; margin-bottom: 0.3rem; color: var(--forest); }
    .bubble ul { padding-left: 1.2rem; margin-top: 0.4rem; }
    .bubble li { margin-bottom: 0.3rem; }

    .typing .bubble { display: flex; align-items: center; gap: 4px; padding: 1rem 1.2rem; }
    .dot { width: 8px; height: 8px; background: var(--muted); border-radius: 50%; animation: bounce 1.4s infinite ease-in-out; }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce { 0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; } 40% { transform: scale(1); opacity: 1; } }

    .input-area { background: var(--white); border-radius: 14px; padding: 1rem; box-shadow: 0 2px 12px rgba(0,0,0,0.06); display: flex; gap: 0.75rem; align-items: flex-end; }
    .input-area textarea { flex: 1; border: 2px solid #e5e7eb; border-radius: 10px; padding: 0.75rem 1rem; font-family: 'Inter', sans-serif; font-size: 0.9rem; resize: none; outline: none; min-height: 48px; max-height: 150px; transition: border-color 0.2s; color: var(--text); }
    .input-area textarea:focus { border-color: var(--forest); }
    .send-btn { background: var(--forest); color: #fff; border: none; border-radius: 10px; padding: 0.75rem 1.25rem; font-family: 'Inter', sans-serif; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.2s, transform 0.1s; white-space: nowrap; }
    .send-btn:hover:not(:disabled) { background: var(--forest-light); transform: translateY(-1px); }
    .send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    footer { text-align: center; padding: 1.5rem; color: var(--muted); font-size: 0.8rem; margin-top: auto; }
    footer a { color: var(--forest); text-decoration: none; font-weight: 600; }
  </style>
</head>
<body>

<nav>
