      Start by narrowing down your destination by asking yourself three things: What kind of experience do you want (adventure, relaxation, culture)? What's your budget range? And how much time do you have?<br><br>
      Once you have those answers, I can give you much more targeted recommendations. Try one of the quick prompts on the left to get started, or tell me your dream destination! ✈️`,

    `Great question! Every trip is different, but here are my universal travel tips: 🗺️<br><br>
      <ul>
        <li>Book flights 6-8 weeks out for the sweet spot of price vs. availability</li>
        <li>Always get travel insurance — it's saved me multiple times</li>
        <li>Pack lighter than you think you need to — you can always buy things there</li>
        <li>Download offline maps before you arrive — data can be spotty abroad</li>
        <li>Talk to locals — they always know the best spots that aren't in any guidebook</li>
      </ul><br>
      Want recommendations for a specific destination? Just ask! 🌟`,

    `Awesome — I love helping plan adventures! 🧭 Here's a starting framework for any trip:<br><br>
      <ul>
        <li><strong>1-3 days:</strong> Focus on one city or region, go deep not wide</li>
        <li><strong>5-7 days:</strong> One country, 2-3 highlights, comfortable pace</li>
        <li><strong>2 weeks:</strong> Regional route or one country thoroughly explored</li>
        <li><strong>1 month+:</strong> Go slow, blend in, live like a local</li>
      </ul><br>
      Tell me your destination and trip length and I'll build you a full itinerary! 🗓️`
  ];

  let fallbackIndex = 0;

  function setMode(mode, btn) {
    travelMode = mode;
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    addMessage('ai', modeIntros[mode]);
  }

  function usePrompt(btn) {
    const text = btn.textContent.replace(/^[\S]+\s/, '').trim();
    document.getElementById('userInput').value = text;
    document.getElementById('userInput').focus();
  }

  function autoResize(textarea) {
    textarea.style.height = 'auto';
    textarea.style.height = Math.min(textarea.scrollHeight, 150) + 'px';
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  }

  function addMessage(role, htmlContent) {
    const messages = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = `message ${role}`;
    div.innerHTML = role === 'ai'
      ? `<div class="avatar ai">🌿</div><div class="bubble"><span class="ai-label">Travel AI</span>${htmlContent}</div>`
      : `<div class="avatar user">👤</div><div class="bubble">${htmlContent}</div>`;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function addTyping() {
    const messages = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = 'message ai typing';
    div.id = 'typingIndicator';
    div.innerHTML = `<div class="avatar ai">🌿</div><div class="bubble"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>`;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    const el = document.getElementById('typingIndicator');
    if (el) el.remove();
  }

  function getResponse(text) {
    const lower = text.toLowerCase();
    for (const r of responses) {
      if (r.keywords.some(k => lower.includes(k))) {
        return r[travelMode] || r['adventure'];
      }
    }
    // Rotate through fallbacks
    const reply = fallbackResponses[fallbackIndex % fallbackResponses.length];
    fallbackIndex++;
    return reply;
  }

  function sendMessage() {
    const input = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const text = input.value.trim();
    if (!text) return;

    addMessage('user', text);
    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;
    addTyping();

    // Simulate typing delay
    setTimeout(() => {
      removeTyping();
      addMessage('ai', getResponse(text));
      sendBtn.disabled = false;
      input.focus();
    }, 1200 + Math.random() * 800);
  }
</script>
</body>
</html>
